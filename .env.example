# ============================================================
# Seller Service Environment
# ============================================================
# Scope:
# - Copy to services/seller-service/.env for local standalone runs.
# - In production, inject only seller-service variables through
#   Secret Manager, Kubernetes Secret, ECS Task Definition, or CI/CD secrets.
# ============================================================

NODE_ENV=development
PORT=3007
APP_VERSION=1.0.0
TYPEORM_LOGGING=false

# PostgreSQL - seller database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bin_ecommerce
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=bin_ecommerce_seller

# Downstream master data services used during submit validation.
CATALOG_SERVICE_URL=http://localhost:3003
LOCATION_SERVICE_URL=http://localhost:3006

# Kafka - used to notify users when seller applications are submitted.
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=seller-service
